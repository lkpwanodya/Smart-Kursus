rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Reusable global validation helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 3. Institutions Collection Access Rules
    match /institutions/{institutionId} {
      allow read: if true;
      allow write: if isValidId(institutionId);
    }

    // 4. Portal Settings Collection Access Rules
    match /portal_settings/{settingId} {
      allow read: if true;
      allow write: if isValidId(settingId);
    }
  }
}
